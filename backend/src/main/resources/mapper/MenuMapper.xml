<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.menurandomizer.mapper.MenuMapper">
    <select id="selectByCategory" resultType="com.menurandomizer.entity.Menu">
        SELECT * FROM menu WHERE category = #{category}
    </select>
    
    <select id="selectRandom" resultType="com.menurandomizer.entity.Menu">
        SELECT * FROM menu ORDER BY RAND() LIMIT 1
    </select>
    
    <select id="selectRandomByCategory" resultType="com.menurandomizer.entity.Menu">
        SELECT * FROM menu WHERE category = #{category} ORDER BY RAND() LIMIT 1
    </select>
</mapper>